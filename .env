# Environment variables for Veta Performance Tracker
# See https://pris.ly/d/connection-strings for reference

# ─── Local Development ───
# When using `npx prisma dev`, the underlying PostgreSQL runs on port 51214
# Use this direct URL for both the app and Prisma CLI:
DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"

# For Railway deployment, set DATABASE_URL to the provisioned Postgres URL, e.g.:
# DATABASE_URL="postgresql://user:pass@host:port/dbname"

# ─── NextAuth ───
NEXTAUTH_SECRET="k8s3f9a7d2e1b4c6h0j5m8n3p7q1r4t6u9w2x5y8z0"
NEXTAUTH_URL="http://localhost:3000"