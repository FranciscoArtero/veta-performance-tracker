// Veta Performance Tracker - Prisma Schema
// PostgreSQL database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  password     String?
  image        String?
  timezone     String        @default("America/Argentina/Buenos_Aires")
  habits       Habit[]
  mentalStates MentalState[]
  tasks        Task[]
  // Future relations:
  // expenses     Expense[]
  // workouts     Workout[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("users")
}

model Habit {
  id         String     @id @default(cuid())
  name       String
  icon       String     @default("check") // Lucide icon name
  color      String     @default("#8b5cf6") // hex color
  frequency  String     @default("daily") // "daily" | "weekly_fixed" | "weekly_flexible"
  weeklyMode String?    // "fixed" | "flexible" (null if daily)
  goalDays   Int?       // e.g. 3 for "3x/week" (only for flexible)
  targetDays Int[]      @default([]) // [1,3,5] = Mon-Wed-Fri (only for fixed, 0=Sun)
  isActive   Boolean    @default(true)
  order      Int        @default(0)
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs       HabitLog[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId])
  @@map("habits")
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime @db.Date // ISO date, stored as date only
  completed Boolean  @default(false)
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([habitId])
  @@index([date])
  @@map("habit_logs")
}

model MentalState {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @db.Date
  mood       Int // 1-10
  motivation Int // 1-10
  notes      String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("mental_states")
}

model Task {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  date      DateTime @db.Date
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([date])
  @@index([userId, date])
  @@map("tasks")
}

