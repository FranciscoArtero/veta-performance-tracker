// CORE OS - Prisma Schema
// PostgreSQL database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String              @id @default(cuid())
  email                String              @unique
  name                 String?
  password             String?
  image                String?
  role                 String              @default("USER") // "USER" | "ADMIN"
  isActive             Boolean             @default(true)
  mustChangePassword   Boolean             @default(false)
  timezone             String              @default("America/Argentina/Buenos_Aires")
  habits               Habit[]
  mentalStates         MentalState[]
  tasks                Task[]
  // Gamification
  currentGlobalStreak  Int                 @default(0)
  longestGlobalStreak  Int                 @default(0)
  lastGlobalStreakDate DateTime?           @db.Date
  unlockedAchievements Achievement[]
  // Gym
  workoutRoutines      WorkoutRoutine[]
  workoutLogs          WorkoutLog[]
  // Hydration
  isHydrationEnabled   Boolean             @default(false)
  hydrationGoalMl      Int                 @default(2000)
  hydrationLogs        HydrationLog[]
  // Money
  financialCategories  FinancialCategory[]
  budgets              Budget[]
  transactions         Transaction[]
  feedbacks            Feedback[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@map("users")
}

model Habit {
  id            String     @id @default(cuid())
  name          String
  icon          String     @default("check") // Lucide icon name
  color         String     @default("#8b5cf6") // hex color
  frequency     String     @default("daily") // "daily" | "weekly_fixed" | "weekly_flexible"
  weeklyMode    String? // "fixed" | "flexible" (null if daily)
  goalDays      Int? // e.g. 3 for "3x/week" (only for flexible)
  targetDays    Int[]      @default([]) // [1,3,5] = Mon-Wed-Fri (only for fixed, 0=Sun)
  isActive      Boolean    @default(true)
  order         Int        @default(0)
  currentStreak Int        @default(0)
  longestStreak Int        @default(0)
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs          HabitLog[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
  @@map("habits")
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime @db.Date // ISO date, stored as date only
  completed Boolean  @default(false)
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([habitId])
  @@index([date])
  @@map("habit_logs")
}

model MentalState {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @db.Date
  mood       Int // 1-10
  motivation Int // 1-10
  notes      String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("mental_states")
}

model Task {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  date      DateTime @db.Date
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([date])
  @@index([userId, date])
  @@map("tasks")
}

// ============================================
// SYSTEM MODELS
// ============================================

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("feedbacks")
}

// ============================================
// GAMIFICATION MODELS
// ============================================

model Achievement {
  id         String   @id @default(cuid())
  userId     String
  type       String // "BRONZE_7", "SILVER_30", "GOLD_100", "DIAMOND_365"
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("achievements")
}

// ============================================
// GYM MODELS
// ============================================

model WorkoutRoutine {
  id          String       @id @default(cuid())
  name        String
  description String?
  color       String       @default("#f97316") // orange
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises   Exercise[]
  logs        WorkoutLog[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@map("workout_routines")
}

model Exercise {
  id        String         @id @default(cuid())
  name      String
  category  String         @default("general") // chest, back, legs, shoulders, arms, core, cardio
  order     Int            @default(0)
  routineId String
  routine   WorkoutRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  sets      ExerciseSet[]
  createdAt DateTime       @default(now())

  @@index([routineId])
  @@map("exercises")
}

model WorkoutLog {
  id               String         @id @default(cuid())
  date             DateTime       @db.Date
  notes            String?
  rpe              Int? // Rate of Perceived Exertion 1-10
  durationMinutes  Int?
  progressPhotoUrl String?
  routineId        String
  routine          WorkoutRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets             ExerciseSet[]
  createdAt        DateTime       @default(now())

  @@index([userId])
  @@index([date])
  @@index([routineId])
  @@map("workout_logs")
}

model ExerciseSet {
  id           String     @id @default(cuid())
  setNumber    Int
  reps         Int?
  weight       Float? // kg
  durationSec  Int? // for timed exercises (planks, etc.)
  exerciseId   String
  exercise     Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  workoutLogId String
  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)

  @@index([workoutLogId])
  @@index([exerciseId])
  @@map("exercise_sets")
}

// ============================================
// HYDRATION MODELS
// ============================================

model HydrationLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  amountMl  Int // ml added in this entry
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([date])
  @@index([userId, date])
  @@map("hydration_logs")
}

// ============================================
// MONEY MODELS (Zero-Based Budgeting)
// ============================================

model FinancialCategory {
  id           String        @id @default(cuid())
  userId       String
  name         String
  icon         String        @default("circle-dollar-sign") // Lucide icon name
  color        String        @default("#10b981") // hex color
  type         String // "Income" | "Expense" | "Savings" | "Debt"
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgets      Budget[]
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
  @@map("financial_categories")
}

model Budget {
  id            String            @id @default(cuid())
  userId        String
  categoryId    String
  month         DateTime          @db.Date // 1st day of the month
  plannedAmount Decimal           @db.Decimal(10, 2)
  actualAmount  Decimal           @default(0) @db.Decimal(10, 2)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      FinancialCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([userId, categoryId, month])
  @@index([userId])
  @@index([categoryId])
  @@index([month])
  @@map("budgets")
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  categoryId  String
  date        DateTime          @db.Date
  amount      Decimal           @db.Decimal(10, 2)
  description String?
  type        String // "Income" | "Expense"
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    FinancialCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([date])
  @@map("transactions")
}
